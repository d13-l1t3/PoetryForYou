# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Database
DATABASE_URL=postgresql+psycopg://poetry:poetry@db:5432/poetry

# Backend URL (for bot → backend communication inside Docker)
BACKEND_BASE_URL=http://backend:8000

# OpenRouter LLM (get key at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-2.0-flash-001

# Voice transcription model (optional)
WHISPER_MODEL=small
